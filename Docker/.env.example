# ==================== DeepSeek 大模型 ====================
# 必填：申请地址 https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# ==================== MySQL 数据库 ====================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=manim_ai
MYSQL_USER=manim
MYSQL_PASSWORD=manim123

# ==================== JWT 密钥 ====================
JWT_SECRET=ManimAI2024SecretKeyForJWTTokenGenerationMustBe256BitsLong!!
JWT_EXPIRATION=86400000

# ==================== Redis ====================
REDIS_URL=redis://redis:6379/0

# ==================== 渲染配置 ====================
RENDER_QUALITY_FLAG=-qm
RENDER_TIMEOUT=120

# ==================== Python AI 服务 ====================
PYTHON_API_URL=http://python-api:8000

# ==================== Ollama（可选，本地嵌入） ====================
OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL_NAME=nomic-embed-text

# ==================== CORS ====================
CORS_ORIGINS=*

# ==================== 速率限制 ====================
RATE_LIMIT_ENABLED=false
