<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.manim.mapper.TaskMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.manim.pojo.Task">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_input" property="userInput" jdbcType="VARCHAR"/>
        <result column="max_retry" property="maxRetry" jdbcType="INTEGER"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="generated_code" property="generatedCode" jdbcType="VARCHAR"/>
        <result column="video_url" property="videoUrl" jdbcType="VARCHAR"/>
        <result column="try_count" property="tryCount" jdbcType="INTEGER"/>
        <result column="error_log" property="errorLog" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 通用查询列 -->
    <sql id="BaseColumns">
        id, user_input, max_retry, status, generated_code, video_url,
        try_count, error_log, create_time, update_time
    </sql>

</mapper>
