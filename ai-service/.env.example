# ==================== DeepSeek 大模型配置 ====================
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# ==================== Ollama 本地嵌入服务 ====================
# 需本地安装 Ollama 并拉取 nomic-embed-text 模型
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL_NAME=nomic-embed-text

# ==================== 渲染配置 ====================
# 渲染质量：-ql(480p) -qm(720p) -qh(1080p) -qk(4K)
RENDER_QUALITY_FLAG=-qm
# 渲染超时时间（秒）
RENDER_TIMEOUT=120

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0

# ==================== CORS 配置 ====================
# 允许的前端域名，逗号分隔。生产环境应指定具体域名
CORS_ORIGINS=*

# ==================== 安全配置 ====================
# 若设置，则服务间调用需携带 X-API-Key 头（留空则关闭认证）
# API_KEY=your_shared_secret_key_here

# ==================== 速率限制 ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_GENERATE_PER_MINUTE=20

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 视频管理 ====================
MAX_VIDEO_AGE_DAYS=30

# ==================== HTTP 代理（可选，用于外网访问） ====================
# HTTP_PROXY=http://127.0.0.1:7897
