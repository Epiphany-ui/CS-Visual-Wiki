from manim import *
import numpy as np

class GradientDescentVisual(Scene):
    def construct(self):
        # 参数配置
        FUNCTION_TYPE = "{{ function_type }}"
        LEARNING_RATE = {{ learning_rate }}
        ITERATIONS = {{ iterations }}
        SPEED = {{ speed }}
        RUN_TIME = 0.6 / SPEED

        title = Text(f"Gradient Descent (lr={LEARNING_RATE})", font_size=30).to_edge(UP)
        self.play(Write(title))

        if FUNCTION_TYPE == "quadratic":
            self._show_1d_quadratic(LEARNING_RATE, ITERATIONS, RUN_TIME, title)
        elif FUNCTION_TYPE == "2d-quadratic":
            self._show_2d_quadratic(LEARNING_RATE, ITERATIONS, RUN_TIME, title)
        else:
            self._show_rosenbrock(LEARNING_RATE, ITERATIONS, RUN_TIME, title)

    def _show_1d_quadratic(self, lr, iters, rt, title):
        """一元二次函数 f(x) = x^2"""
        axes = Axes(
            x_range=[-3, 3, 1], y_range=[-1, 9, 2],
            x_length=6, y_length=4,
            axis_config={"include_numbers": False}
        ).shift(DOWN * 0.3)

        x_label = axes.get_x_axis_label(Text("x"))
        y_label = axes.get_y_axis_label(Text("f(x)"))
        self.play(Create(axes), Write(x_label), Write(y_label))

        # 绘制 f(x) = x^2
        graph = axes.plot(lambda x: x**2, x_range=[-3, 3], color=BLUE, stroke_width=3)
        func_label = MathTex("f(x) = x^2", color=BLUE, font_size=30).next_to(title, DOWN)
        self.play(Create(graph), Write(func_label))

        # 梯度下降
        x = 2.5  # 初始点
        points_and_lines = VGroup()

        for i in range(iters):
            grad = 2 * x       # f'(x) = 2x
            new_x = x - lr * grad

            # 当前点
            y = x**2
            dot = Dot(axes.c2p(x, y), radius=0.1, color=RED)
            self.play(FadeIn(dot, scale=1.5), run_time=rt * 0.5)

            # 切线
            tangent = axes.plot(
                lambda t, x=x, grad=grad: grad * (t - x) + x**2,
                x_range=[x - 0.8, x + 0.8],
                color=YELLOW, stroke_width=2
            )
            self.play(Create(tangent), run_time=rt * 0.3)

            # 下降箭头
            arrow = CurvedArrow(
                axes.c2p(x, y),
                axes.c2p(new_x, new_x**2),
                color=GREEN, radius=-3
            )
            self.play(Create(arrow), run_time=rt * 0.5)

            # 显示信息
            info = Text(f"x={x:.3f} grad={grad:.3f}", font_size=16, color=YELLOW)
            info.to_corner(UR).shift(LEFT * 0.5 + DOWN * (1.5 + i * 0.3))
            self.play(Write(info), run_time=rt * 0.2)

            x = new_x

        # 最终最小值点
        final_dot = Dot(axes.c2p(0, 0), radius=0.15, color=GREEN)
        self.play(FadeIn(final_dot, scale=2), run_time=0.5)
        final_text = Text(f"Minimum at x={x:.4f}", font_size=24, color=GREEN).next_to(func_label, DOWN)
        self.play(Write(final_text))
        self.wait(1.5)

    def _show_2d_quadratic(self, lr, iters, rt, title):
        """二元二次函数 f(x,y) = x^2 + y^2 —— 用等高线 + 下降路径展示"""
        axes = Axes(
            x_range=[-3, 3, 1], y_range=[-3, 3, 1],
            x_length=5, y_length=5,
            axis_config={"include_numbers": False}
        ).shift(DOWN * 0.3)

        x_label = axes.get_x_axis_label(Text("x"))
        y_label = axes.get_y_axis_label(Text("y"))
        self.play(Create(axes), Write(x_label), Write(y_label))

        func_label = Text("f(x,y) = x^2 + y^2", font_size=24, color=BLUE).next_to(title, DOWN)
        self.play(Write(func_label))

        # 梯度下降路径
        x, y = 2.5, 2.0
        path_points = [axes.c2p(x, y)]

        for i in range(iters):
            grad_x, grad_y = 2 * x, 2 * y
            new_x = x - lr * grad_x
            new_y = y - lr * grad_y

            dot = Dot(axes.c2p(x, y), radius=0.1, color=RED)
            self.play(FadeIn(dot, scale=1.5), run_time=rt * 0.4)

            x, y = new_x, new_y
            path_points.append(axes.c2p(x, y))

        # 绘制完整下降路径
        path = VMobject(color=ORANGE, stroke_width=4)
        path.set_points_as_corners(path_points)
        self.play(Create(path), run_time=1)

        final_dot = Dot(path_points[-1], radius=0.15, color=GREEN)
        self.play(FadeIn(final_dot, scale=2), run_time=0.5)
        final_text = Text(f"Minimum at (0,0), final=({x:.4f},{y:.4f})", font_size=20, color=GREEN).next_to(func_label, DOWN)
        self.play(Write(final_text))
        self.wait(1.5)

    def _show_rosenbrock(self, lr, iters, rt, title):
        """Rosenbrock 香蕉函数 —— 经典优化测试函数"""
        axes = Axes(
            x_range=[-2, 2, 0.5], y_range=[-1, 3, 1],
            x_length=6, y_length=4,
            axis_config={"include_numbers": False}
        ).shift(DOWN * 0.3)

        x_label = axes.get_x_axis_label(Text("x"))
        y_label = axes.get_y_axis_label(Text("y"))
        self.play(Create(axes), Write(x_label), Write(y_label))

        func_label = Text("Rosenbrock: f(x,y) = (1-x)^2 + 100(y-x^2)^2", font_size=20, color=BLUE).next_to(title, DOWN)
        self.play(Write(func_label))

        # 梯度下降
        x, y = -1.0, 2.0
        path_points = [axes.c2p(x, y)]

        for i in range(iters):
            # Rosenbrock 梯度
            grad_x = -2 * (1 - x) - 400 * x * (y - x**2)
            grad_y = 200 * (y - x**2)
            new_x = x - lr * max(min(grad_x, 10), -10)  # 梯度裁剪避免飞出去
            new_y = y - lr * max(min(grad_y, 10), -10)

            if i % 3 == 0 or i < 5:
                dot = Dot(axes.c2p(x, y), radius=0.06, color=RED)
                self.play(FadeIn(dot), run_time=rt * 0.3)

            x, y = new_x, new_y
            path_points.append(axes.c2p(x, y))

        path = VMobject(color=ORANGE, stroke_width=3)
        path.set_points_as_corners(path_points)
        self.play(Create(path), run_time=1)

        final_dot = Dot(path_points[-1], radius=0.12, color=GREEN)
        self.play(FadeIn(final_dot, scale=2), run_time=0.5)
        final_text = Text(f"Final: ({x:.3f},{y:.3f})  True min: (1,1)", font_size=20, color=GREEN).next_to(func_label, DOWN)
        self.play(Write(final_text))
        self.wait(1.5)
