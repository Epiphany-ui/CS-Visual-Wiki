from manim import *
import numpy as np
import heapq

class DijkstraShortestPath(Scene):
    def construct(self):
        # 参数配置
        GRAPH_TYPE = "{{ graph_type }}"
        START_NODE = {{ start_node }}
        SPEED = {{ speed }}
        SHOW_DISTANCES = {{ 'True' if show_distances else 'False' }}
        RUN_TIME = 0.7 / SPEED

        # 定义图结构（邻接表 + 坐标）
        if GRAPH_TYPE == "grid":
            # 4x3 网格图
            rows, cols = 3, 4
            nodes = {}
            edges = []
            pos = {}
            idx = 0
            for r in range(rows):
                for c in range(cols):
                    pos[idx] = np.array([c * 1.8 - 2.7, r * -1.8 + 1.8, 0])
                    nodes[idx] = []
                    idx += 1
            # 添加网格边（随机权重 1-9）
            np.random.seed(42)
            for r in range(rows):
                for c in range(cols):
                    u = r * cols + c
                    if c + 1 < cols:
                        v = r * cols + (c + 1)
                        w = np.random.randint(1, 10)
                        edges.append((u, v, w))
                        nodes[u].append((v, w))
                        nodes[v].append((u, w))
                    if r + 1 < rows:
                        v = (r + 1) * cols + c
                        w = np.random.randint(1, 10)
                        edges.append((u, v, w))
                        nodes[u].append((v, w))
                        nodes[v].append((u, w))
        else:
            # 随机连通图 6 节点
            np.random.seed(42)
            n_nodes = 6
            nodes = {i: [] for i in range(n_nodes)}
            pos = {}
            for i in range(n_nodes):
                angle = i * 2 * np.pi / n_nodes
                pos[i] = np.array([2 * np.cos(angle), 2 * np.sin(angle), 0])
            edges = []
            # 保证连通（生成最小生成树 + 随机边）
            for i in range(1, n_nodes):
                w = np.random.randint(1, 10)
                edges.append((i, np.random.randint(0, i), w))
            for _ in range(n_nodes):
                u, v = np.random.randint(0, n_nodes, 2)
                if u != v:
                    w = np.random.randint(1, 10)
                    edges.append((u, v, w))
            for u, v, w in edges:
                nodes[u].append((v, w))
                nodes[v].append((u, w))

        START_NODE = min(START_NODE, len(nodes) - 1)
        n_nodes = len(nodes)

        # 标题
        title = Text(f"Dijkstra Shortest Path (start={START_NODE})", font_size=30).to_edge(UP)
        self.play(Write(title), run_time=0.5)

        # 绘制节点和边
        node_dots = {}
        node_labels = {}
        edge_lines = {}
        edge_labels = {}
        edge_set = set()

        for u, v, w in edges:
            key = tuple(sorted((u, v)))
            if key in edge_set:
                continue
            edge_set.add(key)
            line = Line(pos[u], pos[v], color=GRAY, stroke_width=2)
            edge_lines[key] = line
            mid = (pos[u] + pos[v]) / 2
            wl = Text(str(w), font_size=16, color=GRAY).move_to(mid + UP * 0.15 + RIGHT * 0.1)
            edge_labels[key] = wl

        for i in range(n_nodes):
            dot = Dot(pos[i], radius=0.18, color=BLUE, fill_opacity=0.8)
            node_dots[i] = dot
            node_labels[i] = Text(str(i), font_size=16).move_to(pos[i] + UP * 0.35)

        self.play(
            *[Create(l) for l in edge_lines.values()],
            *[Write(l) for l in edge_labels.values()],
            run_time=1.5
        )
        self.play(
            *[Create(d) for d in node_dots.values()],
            *[Write(l) for l in node_labels.values()],
            run_time=1.0
        )

        # Dijkstra 算法
        INF = 10**9
        dist = {i: INF for i in range(n_nodes)}
        dist[START_NODE] = 0
        visited = set()
        prev = {}

        # 距离标签
        dist_texts = {}
        if SHOW_DISTANCES:
            for i in range(n_nodes):
                t = Text("inf" if i != START_NODE else "0", font_size=14, color=YELLOW)
                t.next_to(node_dots[i], DOWN, buff=0.15)
                dist_texts[i] = t
            self.play(*[Write(t) for t in dist_texts.values()], run_time=0.5)

        # 高亮起始节点
        self.play(node_dots[START_NODE].animate.set_color(GREEN).scale(1.3), run_time=0.5)

        for step in range(n_nodes):
            # 找未访问最小距离节点
            min_dist, u = INF, -1
            for v in range(n_nodes):
                if v not in visited and dist[v] < min_dist:
                    min_dist, u = dist[v], v

            if u == -1:
                break

            visited.add(u)
            self.play(node_dots[u].animate.set_color(ORANGE), run_time=RUN_TIME * 0.5)

            # 更新邻居距离
            for v, w in nodes[u]:
                if v not in visited:
                    old_dist = dist[v]
                    new_dist = dist[u] + w
                    key = tuple(sorted((u, v)))

                    # 高亮边
                    self.play(edge_lines[key].animate.set_color(YELLOW).set_stroke(width=4), run_time=RUN_TIME * 0.3)

                    if new_dist < old_dist:
                        dist[v] = new_dist
                        prev[v] = u
                        if SHOW_DISTANCES and v in dist_texts:
                            new_t = Text(str(new_dist), font_size=14, color=GREEN)
                            new_t.next_to(node_dots[v], DOWN, buff=0.15)
                            self.play(Transform(dist_texts[v], new_t), run_time=RUN_TIME * 0.3)
                            dist_texts[v] = new_t

                    self.play(edge_lines[key].animate.set_color(GRAY).set_stroke(width=2), run_time=RUN_TIME * 0.2)

            self.play(node_dots[u].animate.set_color(GREEN), run_time=RUN_TIME * 0.3)

        # 高亮最短路径（回溯）
        result_text = Text("Shortest distances from node " + str(START_NODE), font_size=22).next_to(title, DOWN)
        self.play(Write(result_text), run_time=0.5)

        dist_display = VGroup()
        for i in range(n_nodes):
            dt = Text(f"d[{i}] = {dist[i] if dist[i] < INF else 'inf'}", font_size=18,
                     color=GREEN if dist[i] < INF else RED)
            dist_display.add(dt)

        dist_display.arrange(DOWN, aligned_edge=LEFT, buff=0.1)
        dist_display.next_to(result_text, DOWN, aligned_edge=LEFT)
        self.play(Write(dist_display), run_time=1.0)

        self.wait(2)
